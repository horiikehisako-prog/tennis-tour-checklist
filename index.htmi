const STATUS_COLORS = { 0: "#888", 1: "#e6a817", 2: "#2e8b57" };

function TourChecklist() {
  const [lang, setLang] = useState("ja");
  const [data, setData] = useState({});
  const [statuses, setStatuses] = useState({});
  const [openSection, setOpenSection] = useState("participants_us");
  const [conn, setConn] = useState("checking"); // checking | ok | error
  const [saveState, setSaveState] = useState("idle"); // idle | saving | saved | error
  const [lastUpdated, setLastUpdated] = useState(null);

  const skipNextRef = useRef(false);

  useEffect(() => {
    const ref = db.ref(DB_PATH);
    const listener = ref.on("value", (snapshot) => {
      if (skipNextRef.current) {
        skipNextRef.current = false;
        setConn("ok");
        return;
      }
      const val = snapshot.val();
      if (val) {
        setData(val.data || {});
        setStatuses(val.statuses || {});
        if (val.updatedAt) setLastUpdated(val.updatedAt);
      }
      setConn("ok");
    }, (err) => {
      setConn("error");
    });
    return () => ref.off("value", listener);
  }, []);

  const t = T[lang];
  const SECTIONS = t.sections;

  const setValue = (id, value) => setData(d => ({ ...d, [id]: value }));
  const setStatus = (id, value) => setStatuses(s => ({ ...s, [id]: value }));

  const handleSave = () => {
    setSaveState("saving");
    const now = new Date().toISOString();
    skipNextRef.current = true;
    db.ref(DB_PATH).set({ data, statuses, updatedAt: now })
      .then(() => {
        setLastUpdated(now);
        setSaveState("saved");
        setTimeout(() => setSaveState("idle"), 2000);
      })
      .catch(() => {
        skipNextRef.current = false;
        setSaveState("error");
        setTimeout(() => setSaveState("idle"), 3000);
      });
  };

  const getSectionProgress = (section) => {
    const criticalFields = section.fields.filter(f => f.critical);
    const filled = criticalFields.filter(f => data[f.id] && data[f.id] !== "");
    return { filled: filled.length, total: criticalFields.length };
  };

  const totalCritical = SECTIONS.flatMap(s => s.fields.filter(f => f.critical));
  const totalFilled = totalCritical.filter(f => data[f.id] && data[f.id] !== "");
  const overallPct = totalCritical.length ? Math.round((totalFilled.length / totalCritical.length) * 100) : 0;

  return (
    <div style={{
      minHeight: "100vh",
      background: "#f5f0e8",
      fontFamily: lang === "ja"
        ? "'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif"
        : "'Georgia', 'Segoe UI', sans-serif",
      padding: "0 0 60px 0"
    }}>
      {/* Header */}
      <div style={{
        background: "linear-gradient(135deg, #1a3a6b 0%, #8b0000 100%)",
        color: "#fff",
        padding: "28px 24px 20px",
        borderBottom: "4px solid #e6a817"
      }}>
        <div style={{ maxWidth: 720, margin: "0 auto" }}>
          {/* Lang switcher */}
          <div style={{ display: "flex", justifyContent: "flex-end", marginBottom: 12 }}>
            <div style={{ display: "flex", background: "rgba(255,255,255,0.15)", borderRadius: 20, padding: 3, gap: 3 }}>
              {["ja", "en"].map(l => (
                <button
                  key={l}
                  onClick={() => setLang(l)}
                  style={{
                    padding: "5px 16px", borderRadius: 16, border: "none", cursor: "pointer",
                    fontWeight: 700, fontSize: 13,
                    background: lang === l ? "#e6a817" : "transparent",
                    color: lang === l ? "#1a3a6b" : "rgba(255,255,255,0.8)",
                    transition: "all 0.2s", letterSpacing: l === "ja" ? 1 : 0,
                  }}
                >
                  {l === "ja" ? "🇯🇵 日本語" : "🇺🇸 English"}
                </button>
              ))}
            </div>
          </div>

          <div style={{ fontSize: 11, letterSpacing: 3, opacity: 0.7, marginBottom: 6 }}>
            🎾 JAPAN–USA TENNIS TOUR
          </div>
          <h1 style={{ margin: 0, fontSize: 21, fontWeight: 700, lineHeight: 1.3 }}>{t.appTitle}</h1>
          <div style={{ marginTop: 5, fontSize: 13, opacity: 0.85 }}>{t.appSubtitle}</div>

          {/* Progress */}
          <div style={{ marginTop: 18, background: "rgba(255,255,255,0.15)", borderRadius: 8, padding: "12px 16px" }}>
            <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, marginBottom: 6 }}>
              <span>{t.requiredProgress}</span>
              <span style={{ fontWeight: 700, color: "#e6a817" }}>
                {totalFilled.length} / {totalCritical.length} ({overallPct}%)
              </span>
            </div>
            <div style={{ height: 8, background: "rgba(255,255,255,0.2)", borderRadius: 4, overflow: "hidden" }}>
              <div style={{ height: "100%", width: `${overallPct}%`, background: "#e6a817", borderRadius: 4, transition: "width 0.5s" }} />
            </div>
          </div>

          {/* Connection status */}
          <div style={{ marginTop: 12, fontSize: 12, fontWeight: 600 }}>
            {conn === "checking" ? t.connChecking : conn === "ok" ? t.connOk : t.connError}
          </div>

          {/* Save button */}
          <div style={{ marginTop: 10 }}>
            <button
              onClick={handleSave}
              disabled={saveState === "saving"}
              style={{
                width: "100%", padding: "12px 16px", borderRadius: 8, border: "none",
                cursor: saveState === "saving" ? "default" : "pointer",
                fontWeight: 700, fontSize: 15,
                background: saveState === "saved" ? "#2e8b57" : saveState === "error" ? "#c00" : "#e6a817",
                color: saveState === "saved" || saveState === "error" ? "#fff" : "#1a3a6b",
                opacity: saveState === "saving" ? 0.7 : 1,
              }}
            >
              {saveState === "saving" ? t.saving : saveState === "saved" ? t.saved : saveState === "error" ? `⚠️ ${t.saveError}` : t.saveButton}
            </button>
          </div>

          <div style={{ marginTop: 8, fontSize: 11, opacity: 0.75 }}>
            {t.lastUpdated}: {lastUpdated ? new Date(lastUpdated).toLocaleString(lang === "ja" ? "ja-JP" : "en-US") : t.never}
          </div>
        </div>
      </div>

      <div style={{ maxWidth: 720, margin: "0 auto", padding: "20px 16px" }}>
        {/* Warning */}
        <div style={{ background: "#fff8e1", border: "2px solid #e6a817", borderRadius: 10, padding: "12px 16px", marginBottom: 20, fontSize: 13, lineHeight: 1.7 }}>
          <div style={{ fontWeight: 700, marginBottom: 4 }}>{t.warningTitle}</div>
          {t.warningBody.split("\n").map((line, i) => <div key={i}>{line}</div>)}
        </div>

        {/* Sections */}
        {SECTIONS.map(section => {
          const prog = getSectionProgress(section);
          const isOpen = openSection === section.id;
          return (
            <div key={section.id} style={{
              background: "#fff", borderRadius: 12, marginBottom: 12,
              boxShadow: "0 2px 8px rgba(0,0,0,0.08)", overflow: "hidden",
              border: `2px solid ${isOpen ? section.color : "transparent"}`
            }}>
              <button
                onClick={() => setOpenSection(isOpen ? null : section.id)}
                style={{
                  width: "100%", display: "flex", alignItems: "center",
                  justifyContent: "space-between", padding: "14px 16px",
                  background: isOpen ? section.color : "#fff",
                  color: isOpen ? "#fff" : "#333",
                  border: "none", cursor: "pointer", textAlign: "left", transition: "background 0.2s"
                }}
              >
                <div style={{ fontWeight: 700, fontSize: 15 }}>{section.title}</div>
                <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                  <div style={{
                    fontSize: 12,
                    background: prog.filled === prog.total ? "#2e8b57" : "rgba(0,0,0,0.15)",
                    color: isOpen ? "#fff" : (prog.filled === prog.total ? "#fff" : "#555"),
                    padding: "2px 8px", borderRadius: 12, fontWeight: 600
                  }}>
                    {prog.filled}/{prog.total} {t.required}
                  </div>
                  <span style={{ fontSize: 16 }}>{isOpen ? "▲" : "▼"}</span>
                </div>
              </button>

              {isOpen && (
                <div style={{ padding: "16px 16px 20px" }}>
                  {section.fields.map(field => {
                    const statusIdx = statuses[field.id] !== undefined ? statuses[field.id] : 0;
                    return (
                      <div key={field.id} style={{ marginBottom: 16 }}>
                        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 5 }}>
                          <label style={{ fontSize: 13, fontWeight: 600, color: "#333", display: "flex", alignItems: "center", gap: 5 }}>
                            {field.critical && (
                              <span style={{ color: "#fff", background: "#c00", fontSize: 10, fontWeight: 700, padding: "1px 5px", borderRadius: 4 }}>
                                {t.required}
                              </span>
                            )}
                            {field.label}
                          </label>
                          <div style={{ display: "flex", gap: 4, alignItems: "center", flexShrink: 0, marginLeft: 8 }}>
                            {[0, 1, 2].map(i => (
                              <button
                                key={i}
                                title={t.statuses[i]}
                                onClick={() => setStatus(field.id, i)}
                                style={{
                                  width: i === statusIdx ? 26 : 18, height: 18, borderRadius: 9,
                                  background: statusIdx === i ? STATUS_COLORS[i] : "#e0e0e0",
                                  border: "none", cursor: "pointer", transition: "all 0.2s",
                                  fontSize: i === 2 && statusIdx === 2 ? 11 : 0,
                                  color: "#fff", fontWeight: 700,
                                  display: "flex", alignItems: "center", justifyContent: "center"
                                }}
                              >
                                {i === 2 && statusIdx === 2 ? "✓" : ""}
                              </button>
                            ))}
                            <span style={{ fontSize: 10, color: STATUS_COLORS[statusIdx], fontWeight: 600, minWidth: 60 }}>
                              {t.statuses[statusIdx]}
                            </span>
                          </div>
                        </div>

                        {field.type === "textarea" ? (
                          <textarea
                            value={data[field.id] || ""}
                            onChange={e => setValue(field.id, e.target.value)}
                            placeholder={field.placeholder}
                            rows={3}
                            style={{
                              width: "100%", padding: "8px 10px",
                              border: `1.5px solid ${data[field.id] ? section.color : "#ddd"}`,
                              borderRadius: 8, fontSize: 13, resize: "vertical",
                              fontFamily: "inherit", lineHeight: 1.6
                            }}
                          />
                        ) : field.type === "select" ? (
                          <select
                            value={data[field.id] || ""}
                            onChange={e => setValue(field.id, e.target.value)}
                            style={{
                              width: "100%", padding: "8px 10px",
                              border: `1.5px solid ${data[field.id] ? section.color : "#ddd"}`,
                              borderRadius: 8, fontSize: 13, background: "#fff", cursor: "pointer"
                            }}
                          >
                            <option value="">{t.selectPlaceholder}</option>
                            {field.options.map(o => <option key={o} value={o}>{o}</option>)}
                          </select>
                        ) : (
                          <input
                            type={field.type}
                            value={data[field.id] || ""}
                            onChange={e => setValue(field.id, e.target.value)}
                            placeholder={field.placeholder}
                            style={{
                              width: "100%", padding: "8px 10px",
                              border: `1.5px solid ${data[field.id] ? section.color : "#ddd"}`,
                              borderRadius: 8, fontSize: 13, fontFamily: "inherit"
                            }}
                          />
                        )}
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })}

        {/* Summary */}
        <div style={{ marginTop: 16, background: "#1a3a6b", color: "#fff", borderRadius: 12, padding: "16px 20px", fontSize: 13, lineHeight: 1.8 }}>
          <div style={{ fontWeight: 700, marginBottom: 8, color: "#e6a817" }}>{t.summaryTitle}</div>
          {SECTIONS.map(s => {
            const p = getSectionProgress(s);
            return (
              <div key={s.id} style={{ display: "flex", justifyContent: "space-between", borderBottom: "1px solid rgba(255,255,255,0.1)", padding: "3px 0" }}>
                <span style={{ fontSize: 12 }}>{s.title}</span>
                <span style={{ fontSize: 12, color: p.filled === p.total ? "#7dffb0" : "#e6a817" }}>
                  {p.filled === p.total ? "✅" : `${p.filled}/${p.total}`}
                </span>
              </div>
            );
          })}
        </div>

        {/* Bottom save button (for long pages) */}
        <div style={{ marginTop: 16 }}>
          <button
            onClick={handleSave}
            disabled={saveState === "saving"}
            style={{
              width: "100%", padding: "14px 16px", borderRadius: 10, border: "none",
              cursor: saveState === "saving" ? "default" : "pointer",
              fontWeight: 700, fontSize: 16,
              background: saveState === "saved" ? "#2e8b57" : saveState === "error" ? "#c00" : "#e6a817",
              color: saveState === "saved" || saveState === "error" ? "#fff" : "#1a3a6b",
              opacity: saveState === "saving" ? 0.7 : 1,
              boxShadow: "0 2px 8px rgba(0,0,0,0.15)",
            }}
          >
            {saveState === "saving" ? t.saving : saveState === "saved" ? t.saved : saveState === "error" ? `⚠️ ${t.saveError}` : t.saveButton}
          </button>
        </div>
      </div>
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById("root"));
root.render(<TourChecklist />);
</script>
</body>
</html>
